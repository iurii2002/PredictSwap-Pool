# ─── Wallets ──────────────────────────────────────────────────────────────────

# Private key of the deployer wallet (pays gas for all deployments)
DEPLOYER_PRIVATE_KEY=0x...
OPERATOR_PRIVATE_KEY=

# Protocol owner address — receives contract ownership after deploy.
# Use a multisig (Safe) in production, not the deployer EOA.
OWNER_ADDRESS=0x...

# Used for non critical operations
OPERATOR_ADDRESS=0x...

# ─── RPC Endpoints ────────────────────────────────────────────────────────────

POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org

POLYGON_TESTNET_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
BSC_TESTNET_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org

# ─── Explorer API Keys (for --verify) ────────────────────────────────────────

ETHERSCAN_API_KEY=

# ─── Token Addresses (set after bridge contracts are deployed) ────────────────

# Native Polymarket ERC-1155 contract on Polygon
POLYMARKET_TOKEN_ADDRESS=0x...

# WrappedOpinionToken on Polygon (deployed as part of bridge)
OPINION_TOKEN_ADDRESS=0x...

# ─── Deployed Pool Contracts (set after running Deploy.s.sol) ─────────────────

FEE_COLLECTOR_ADDRESS=0x...
POOL_FACTORY_ADDRESS=0x...

# ─── CreatePool params (set before running CreatePool.s.sol) ──────────────────

# Polymarket ERC-1155 token ID for the event-outcome (e.g. BTC >100k YES)
MARKET_A_TOKEN_ID=88902058027062214140177978007942040532071439710160833384602336149457247354303
MARKET_A_DECIMALS=6
MARKET_A_NAME=Polymarket

# Matching WrappedOpinion token ID for the same event-outcome
MARKET_B_TOKEN_ID=38963932780906540363109247799097676402090390705396650950183721237182147511527
MARKET_B_DECIMALS=18
MARKET_B_NAME=Opinion

# LP token metadata
MARKET_A_LP_NAME='PredictSwap. Polymarket LP'
MARKET_A_LP_SYMBOL='PS-P'

MARKET_B_LP_NAME='PredictSwap. Opinion LP'
MARKET_B_LP_SYMBOL='PS-O'

# ─── SetFees params (set before running SetFees.s.sol) ────────────────────────

# Basis points (1 bps = 0.01%). Default: LP=30, Protocol=10
# Hard caps: LP max 100 bps (1%), Protocol max 50 bps (0.5%)
LP_FEE_BPS=30
PROTOCOL_FEE_BPS=10

# ─── WithdrawFees params (set before running WithdrawFees.s.sol) ──────────────

# ERC-1155 token contract to withdraw fees from (polymarket or opinion token)
FEE_TOKEN_ADDRESS=0x...

# Token ID to withdraw
FEE_TOKEN_ID=1

# Address to receive the fees (team treasury or multisig)
FEE_RECIPIENT_ADDRESS=0x...